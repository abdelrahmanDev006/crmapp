generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id        Int       @id @default(autoincrement())
  code      Int       @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  isDeleted Boolean   @default(false)
  clients   Client[]
  users     User[]    @relation("RegionToUser")

  @@index([isDeleted])
}

model User {
  id             Int            @id @default(autoincrement())
  name           String
  email          String         @unique
  passwordHash   String
  role           Role           @default(REPRESENTATIVE)
  isActive       Boolean        @default(true)
  tokenVersion   Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  allowedDate    String?
  activityLogs   ActivityLog[]  @relation("UserLogs")
  createdClients Client[]       @relation("ClientCreator")
  visits         VisitHistory[] @relation("VisitUser")
  regions        Region[]       @relation("RegionToUser")

  @@index([role])
}

model Client {
  id                             Int            @id @default(autoincrement())
  name                           String
  phone                          String
  phoneNormalized                String?
  address                        String
  products                       String
  regionId                       Int
  visitType                      VisitType
  status                         ClientStatus   @default(ACTIVE)
  nextVisitDate                  DateTime
  createdById                    Int?
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime       @updatedAt
  locationUrl                    String?
  price                          String?
  priceValue                     Decimal?       @db.Decimal(10, 2)
  customVisitIntervalDays        Int?
  noAnswerCount                  Int            @default(0)
  note                           String?
  pendingCustomVisitIntervalDays Int?
  pendingNote                    String?
  pendingOutcome                 ClientStatus?
  pendingVisitType               VisitType?
  deletedAt                      DateTime?
  isExceptional                  Boolean        @default(false)
  exceptionalReason              String?
  exceptionalNextVisitDate       DateTime?
  isDeleted                      Boolean        @default(false)
  createdBy                      User?          @relation("ClientCreator", fields: [createdById], references: [id])
  region                         Region         @relation(fields: [regionId], references: [id])
  visits                         VisitHistory[]

  @@index([isDeleted, regionId, status, nextVisitDate])
  @@index([isDeleted, regionId, nextVisitDate])
  @@index([isDeleted, status, nextVisitDate])
  @@index([isDeleted, nextVisitDate])
  @@index([isDeleted, regionId, status])
  @@index([phoneNormalized])
}

model VisitHistory {
  id                    Int            @id @default(autoincrement())
  clientId              Int
  visitedById           Int
  visitDate             DateTime       @default(now())
  previousStatus        ClientStatus
  newStatus             ClientStatus
  note                  String?
  paymentMethod         PaymentMethod?
  collectedAmount       Float?
  deliveredProducts     String?
  previousNextVisitDate DateTime?
  newNextVisitDate      DateTime?
  createdAt             DateTime       @default(now())
  client                Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visitedBy             User           @relation("VisitUser", fields: [visitedById], references: [id])

  @@index([clientId, visitDate])
  @@index([visitedById, visitDate])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  entityType String
  entityId   Int?
  entityName String?
  details    String?
  createdAt  DateTime @default(now())
  user       User     @relation("UserLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum Role {
  ADMIN
  REPRESENTATIVE
}

enum VisitType {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
  ONE_TIME
}

enum ClientStatus {
  ACTIVE
  NO_ANSWER
  REJECTED
  PENDING_APPROVAL
}

enum PaymentMethod {
  CASH
  VISA
}
