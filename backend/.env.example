NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_app?schema=public"
JWT_SECRET="CHANGE_ME_WITH_AT_LEAST_32_STRONG_CHARACTERS"
JWT_EXPIRES_IN="1d"
REJECTED_RETRY_DAYS=28
WORK_TIMEZONE="Africa/Cairo"
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
CORS_CREDENTIALS=true
TRUST_PROXY=false
JSON_BODY_LIMIT="1mb"
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=100
AUTH_COOKIE_NAME="crm_access_token"
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_HOURS=24
SEED_ADMIN_EMAIL="admin@crm.local"
SEED_ADMIN_PASSWORD=""
SEED_REP_COUNT=6
SEED_REP_EMAIL_PREFIX="rep"
SEED_REP_DEFAULT_PASSWORD=""
