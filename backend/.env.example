NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_app?schema=public"
JWT_SECRET="super-secret-change-me"
JWT_EXPIRES_IN="1d"
REJECTED_RETRY_DAYS=28
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
CORS_CREDENTIALS=true
TRUST_PROXY=false
JSON_BODY_LIMIT="1mb"
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=100
WHATSAPP_CLOUD_ENABLED=false
WHATSAPP_CLOUD_ACCESS_TOKEN=""
WHATSAPP_CLOUD_PHONE_NUMBER_ID=""
WHATSAPP_CLOUD_API_VERSION="v21.0"
WHATSAPP_REQUEST_TIMEOUT_MS=15000
WHATSAPP_MESSAGE_DELAY_MS=150
SEED_ADMIN_EMAIL="admin@crm.local"
SEED_ADMIN_PASSWORD=""
SEED_REP_COUNT=6
SEED_REP_EMAIL_PREFIX="rep"
SEED_REP_DEFAULT_PASSWORD=""
