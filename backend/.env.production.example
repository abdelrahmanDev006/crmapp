NODE_ENV=production
PORT=5000
DATABASE_URL="postgresql://crm_user:CHANGE_ME@postgres:5432/crm_app?schema=public"
DIRECT_URL="postgresql://crm_user:CHANGE_ME@postgres:5432/crm_app?schema=public"
JWT_SECRET="CHANGE_ME_WITH_AT_LEAST_32_STRONG_CHARACTERS"
JWT_EXPIRES_IN="1d"
REJECTED_RETRY_DAYS=28
ALLOWED_ORIGINS="https://crm.example.com"
CORS_CREDENTIALS=true
TRUST_PROXY=true
JSON_BODY_LIMIT="1mb"
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=50
WHATSAPP_CLOUD_ENABLED=false
WHATSAPP_CLOUD_ACCESS_TOKEN=""
WHATSAPP_CLOUD_PHONE_NUMBER_ID=""
WHATSAPP_CLOUD_API_VERSION="v21.0"
WHATSAPP_REQUEST_TIMEOUT_MS=15000
WHATSAPP_MESSAGE_DELAY_MS=150

# Optional seed/bootstrap values (production-safe defaults)
SEED_MODE="ADMIN_ONLY"
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_REP_COUNT=0
SEED_REP_EMAIL_PREFIX="rep"
SEED_REP_DEFAULT_PASSWORD=""
